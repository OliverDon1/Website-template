@page
@model ServeyApplication.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5" style="max-width: 450px;">
    <h2 class="mb-4 text-center">Login</h2>

    <form method="post">
        <div class="form-group mb-3">
            <label asp-for="Input.Username" class="form-label"></label>
            <input asp-for="Input.Username" class="form-control" />
            <span asp-validation-for="Input.Username" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" type="password" class="form-control" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Login</button>

        <div class="form-group">
            <input type="checkbox" asp-for="RememberMe" />
            <label asp-for="RememberMe">Remember Me</label>
        </div>

        <div class="text-center mt-3">
            <a asp-page="/CreateAccount">Create a new account</a>
        </div>
        <div class="mt-3 text-center">
            <a asp-page="/ForgotPassword">Forgot your password?</a>
        </div>

        @if (Model.Message != null)
        {
            <p class="text-danger mt-3">@Html.Raw(Model.Message)</p>
        }

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}