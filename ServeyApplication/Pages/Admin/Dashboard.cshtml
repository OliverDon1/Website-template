@page
@using Microsoft.AspNetCore.Authorization;
@model ServeyApplication.Pages.Admin.DashboardModel
@attribute [Authorize(Roles = "Admin")]

<h1 class="mb-4">Admin Dashboard</h1>

<div class="row">
    <div class="col-md-6">

        <form method="get" class="mb-3 d-flex">
            <input type="text" name="search" value="@Model.Search" class="form-control me-2" placeholder="Search users..." />
            <button class="btn btn-primary">Search</button>
        </form>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Role</th>
                    <th style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.Role</td>
                        <td>

                            <!-- Reset Password -->
                            <form method="post" asp-page-handler="SelectUser" class="d-inline">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="btn btn-sm btn-warning">Reset</button>
                            </form>

                            <!-- Delete User -->
                            <form method="post" asp-page-handler="DeleteUser" class="d-inline ms-1">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure you want to delete this user?');">
                                    Delete
                                </button>
                            </form>
                            <!-- Promote to Admin -->
                            @if (user.Role != "Admin")
                            {
                                <form method="post" asp-page-handler="Promote" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-sm btn-success">Make Admin</button>
                                </form>
                            }
                            else
                            {
                                <!-- Demote Admin -->
                                <form method="post" asp-page-handler="Demote" class="d-inline ms-1">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-sm btn-secondary">Remove Admin</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
            </tbody>
        </table>
    </div>

    <div class="col-md-6">
        @if (Model.SelectedUser != null)
        {
            <div class="card shadow-sm p-4">
                <h4>Reset Password for @Model.SelectedUser.Email</h4>

                <form method="post" asp-page-handler="ResetPassword">
                    <input type="hidden" name="id" value="@Model.SelectedUser.Id" />

                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" class="form-control" asp-for="NewPassword" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" asp-for="ConfirmPassword" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button class="btn btn-primary">Save</button>
                </form>
            </div>
        }
    </div>

    <div class="card p-3 mb-4 shadow-sm">
        <h5>Maintenance Tools</h5>
        <form method="post" asp-page-handler="CleanTokens">
            <button class="btn btn-danger"
                    onclick="return confirm('Delete all expired or used password reset tokens?');">
                Clean Expired Tokens
            </button>
        </form>

        @if (TempData["CleanupMessage"] != null)
        {
            <div class="alert alert-success mt-3">
                @TempData["CleanupMessage"]
            </div>
        }
    </div>
</div>

